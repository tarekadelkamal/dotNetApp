pipeline {
    agent any

    parameters {
        choice(name: 'ACTION', choices: ['Deploy', 'Rollback'], description: 'Choose whether to Deploy a new build or Rollback to a previous revision')
        choice(name: 'ENVIRONMENT', choices: ['staging', 'production'], description: 'Target environment')
        string(name: 'REVISION', defaultValue: '0', description: 'Revision to rollback to (0 means previous release, only used if ACTION is Rollback)')
    }

    stages {
       /* stage('checkout'){
            steps{
                 git branch: 'main', url: 'https://github.com/tarekadelkamal/dotNetApp.git'
            }
        }*/
        stage('build & push') {
            when {
                expression { params.ACTION == 'Deploy' }
            }
            steps {
                dir('GameZone') {
                   withCredentials([usernamePassword(credentialsId: 'dockerhub', passwordVariable: 'pass', usernameVariable: 'user')]) 
                    {
                         sh 'echo $pass | docker login -u $user --password-stdin'
                         sh 'docker compose build webapp'
                         sh "docker tag gamezone-webapp:latest tarek2020/dotnetapp:${env.BUILD_NUMBER}"
                         sh "docker push tarek2020/dotnetapp:${env.BUILD_NUMBER}"
                    } 
                }
            }
        }
        
        stage('Deploy with Helm') {
            when {
                expression { params.ACTION == 'Deploy' }
            }
            steps {
               dir('GameZone') { 
                   // Deploy using the specific environment values file
                   sh """
                   helm upgrade --install gamezone-${params.ENVIRONMENT} k8s/helm-charts \
                     -f k8s/helm-charts/values-${params.ENVIRONMENT}.yaml \
                     --set app.image.tag=${env.BUILD_NUMBER} \
                     --namespace ${params.ENVIRONMENT} \
                     --create-namespace \
                     --wait
                   """
               }
            }
        }

        stage('Rollback with Helm') {
            when {
                expression { params.ACTION == 'Rollback' }
            }
            steps {
               dir('GameZone') { 
                   // Rollback to the specified revision
                   sh "helm rollback gamezone-${params.ENVIRONMENT} ${params.REVISION} --namespace ${params.ENVIRONMENT} --wait"
               }
            }
        }
    }
}
